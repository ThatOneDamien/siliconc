#assert(10 + 16 == 26, "Fail");
#assert(110 - 15 == 95, "Fail");
#assert(12 * 14 == 168, "Fail");
#assert(100 / 10 == 10, "Fail");
#assert(13 % 4 == 1, "Fail");

#const shift_test1: int = 0xFC0000BA;
#const shift_test2: int = 0x40000000;
#assert((shift_test1 << 4) == 0xC0000BA0, "Fail");
#assert((shift_test1 >> 4) == 0x0FC0000B, "Fail");
#assert((shift_test1 >>> 4) == 0xFFC0000B, "Fail");
#assert((shift_test2 >> 4) == 0x04000000, "Fail");
#assert((shift_test2 >>> 4) == 0x04000000, "Fail");
#assert((0xC & 0xB) == 0x8, "Fail");
#assert((0xC ^ 0xB) == 0x7, "Fail");
#assert((0xC | 0xB) == 0xF, "Fail");
#assert(cast<uint>(-1) == 0xFFFFFFFF, "Fail");
#assert(cast<uint>(~1) == 0xFFFFFFFE, "Fail");
#assert(!(false), "Fail");
#assert(!(10 == 100), "Fail");
#assert(true && true, "Fail");
#assert(true || false, "Fail");
#assert(128 == 0x80, "Fail");
#assert(1000 != 1, "Fail");
#assert(-20 <= 500, "Fail");
#assert(500 <= 500, "Fail");
#assert(40 >= -5, "Fail");
#assert(-40 >= -40, "Fail");
#assert(0 < 1, "Fail");
#assert(1 > 0, "Fail");

#const a: int = 1 / 0; // #error: evaluates to 0
